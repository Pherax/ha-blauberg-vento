"""Fan platform for Blauberg Vento V.2."""
from __future__ import annotations

from typing import Any

from homeassistant.components.fan import FanEntity, FanEntityFeature
from homeassistant.config_entries import ConfigEntry
from homeassistant.core import HomeAssistant
from homeassistant.helpers.entity_platform import AddEntitiesCallback

from .const import DOMAIN, P_POWER, P_SPEED, SPEED_PCT_MAP
from .coordinator import VentoCoordinator
from .entity_base import VentoEntity


async def async_setup_entry(
    hass: HomeAssistant, entry: ConfigEntry, async_add_entities: AddEntitiesCallback
) -> None:
    coordinator: VentoCoordinator = hass.data[DOMAIN][entry.entry_id]
    async_add_entities([VentoFan(coordinator, entry)])


class VentoFan(VentoEntity, FanEntity):
    """Main fan entity – On/Off and three preset speed levels.

    Speed mapping:
      33 % → Speed 1 (code 1)
      66 % → Speed 2 (code 2)
     100 % → Speed 3 (code 3)

    Setting 0 % turns the unit off.
    The manual-speed mode (code 255) is accessible via the 'Manual Speed Value'
    Number entity and is reflected in the 'Speed Mode' sensor.
    """

    _attr_name = None           # entity name = device name
    _attr_icon = "mdi:hvac"
    _attr_speed_count = 3
    _attr_supported_features = (
        FanEntityFeature.SET_SPEED
        | FanEntityFeature.TURN_ON
        | FanEntityFeature.TURN_OFF
    )

    def __init__(self, coordinator: VentoCoordinator, entry: ConfigEntry) -> None:
        super().__init__(coordinator, entry, "fan")

    @property
    def is_on(self) -> bool | None:
        if self.coordinator.data is None:
            return None
        return bool(self.coordinator.data.get(P_POWER, 0))

    @property
    def percentage(self) -> int | None:
        """Return current speed as a percentage; None when in manual mode."""
        if self.coordinator.data is None:
            return None
        code = self.coordinator.data.get(P_SPEED)
        return SPEED_PCT_MAP.get(code)  # returns None for 255 (manual)

    async def async_turn_on(
        self,
        percentage: int | None = None,
        preset_mode: str | None = None,
        **kwargs: Any,
    ) -> None:
        if percentage is not None:
            # Power on and set speed in two writes
            await self.coordinator.async_write_param(P_POWER, 1, refresh=False)
            await self.coordinator.async_write_param(P_SPEED, _pct_to_code(percentage))
        else:
            await self.coordinator.async_write_param(P_POWER, 1)

    async def async_turn_off(self, **kwargs: Any) -> None:
        await self.coordinator.async_write_param(P_POWER, 0)

    async def async_set_percentage(self, percentage: int) -> None:
        if percentage == 0:
            await self.async_turn_off()
            return
        await self.coordinator.async_write_param(P_SPEED, _pct_to_code(percentage))


def _pct_to_code(pct: int) -> int:
    """Map an arbitrary 1-100 % to the closest preset speed code."""
    if pct <= 33:
        return 1
    if pct <= 66:
        return 2
    return 3
